  "info": {
    "_postman_id": "8da8ccc7-8552-42f9-a8aa-c2dc52ae821f",
    "name": "Apache Solr REST API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Apache Solr exposes a REST API under /api (v2) on each Solr node. This specification\ncovers collection lifecycle, core administration, per-collection schema/config/update\noperations, and the legacy Collections admin handler still supported under\n/solr/admin/collections.\n\nAuthentication is pluggable (Basic, JWT, Certificate). Where security is enabled,\nBasic authentication is the most common configuration.\n\n\nContact Support:\n Name: Apache Solr Reference Guide",
      "type": "text/plain"
    }
  }
